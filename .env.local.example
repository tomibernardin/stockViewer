# Copia este archivo a .env.local y completa tu clave de Finnhub.
# .env.local está en .gitignore — nunca se sube al repo.
#
# Obtener clave gratuita en: https://finnhub.io/dashboard
# Tier free: 60 req/min — más que suficiente para 35 tickers.
#
# En Vercel (producción): Settings → Environment Variables → FINNHUB_API_KEY

FINNHUB_API_KEY=your_finnhub_api_key_here
